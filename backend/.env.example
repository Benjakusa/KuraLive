# REQUIRED
SECRET_KEY=generate-a-random-64-char-string
DATABASE_URL=postgresql://user:password@host:5432/uchaguzi360

# M-Pesa Daraja (required for payments)
DARAJA_CONSUMER_KEY=your-daraja-consumer-key
DARAJA_CONSUMER_SECRET=your-daraja-consumer-secret
DARAJA_PASSKEY=your-daraja-passkey
DARAJA_SHORT_CODE=174379
DARAJA_ENV=sandbox

# Email (required for password reset & agent emails)
RESEND_API_KEY=your-resend-api-key

# Twilio SMS (required for SMS broadcasting)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# OPTIONAL
FRONTEND_URL=http://localhost:5173
UPLOAD_FOLDER=uploads
FLASK_DEBUG=false

# TalkingAfrica SMS API (alternative to Twilio)
TALKINGAFRICA_BASE_URL=
TALKINGAFRICA_API_KEY=
TALKINGAFRICA_SENDER_ID=Uchaguzi360
TALKINGAFRICA_SHORTCODE=

# Social Media OAuth (not yet implemented)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# Redis (for background tasks, rate limiting)
REDIS_URL=

# Load testing (disables rate limiting)
# DISABLE_RATE_LIMIT=true
