# KuraLive Backend Environment Configuration
# Copy this file to .env and fill in your details

# --- APPLICATION ---
FLASK_DEBUG=false
SECRET_KEY=generate_a_secure_random_string_here
FRONTEND_URL=http://localhost:5173
UPLOAD_FOLDER=/app/uploads

# --- INFRASTRUCTURE ---
# Primary database connection (usually pointing to PgBouncer)
DATABASE_URL=postgresql://user:password@hostname:6432/uchaguzi360
# Direct DB connection (for migrations or tools that hate connection pools)
DATABASE_URL_DIRECT=postgresql://user:password@hostname:5432/uchaguzi360

REDIS_URL=redis://localhost:6379/0

# --- PAGINATION & RATE LIMITING ---
MAX_PAGE_SIZE=1000
DEFAULT_PAGE_SIZE=100
# Set to 'true' to completely disable rate limits (e.g. for load testing)
DISABLE_RATE_LIMIT=false

# --- SERVICES ---

# RESEND (Email Delivery)
RESEND_API_KEY=re_123456789

# TWILIO (SMS Engine)
TWILIO_ACCOUNT_SID=AC123...
TWILIO_AUTH_TOKEN=auth_token_here
TWILIO_PHONE_NUMBER=+123456789

# TALKING AFRICA (Alternative SMS provider, if applicable)
TALKINGAFRICA_BASE_URL=https://api.talkingafrica.com
TALKINGAFRICA_API_KEY=ta_12345
TALKINGAFRICA_SENDER_ID=Uchaguzi360

# DARAJA (M-PESA Integration)
DARAJA_ENV=sandbox # either 'sandbox' or 'production'
DARAJA_SHORT_CODE=174379
DARAJA_CONSUMER_KEY=consumer_key_here
DARAJA_CONSUMER_SECRET=consumer_secret_here
DARAJA_PASSKEY=passkey_here
